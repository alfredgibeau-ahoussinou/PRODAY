# Copier vers .env et remplir avec la console Firebase (Projet ProDay)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# OAuth Google (Firebase Console → Authentication → Google → Web client ID + Expo)
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Région Cloud Functions si différente de us-central1 (ex. europe-west1)
# EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west1

# Stripe (Cloud Functions — ne pas mettre la clé secrète ici)
# firebase functions:config:set stripe.secret_key="sk_..." stripe.webhook_secret="whsec_..."

# Mistral IA — vérification documents coach/agent/organisateur (Cloud Functions uniquement)
# firebase functions:config:set mistral.api_key="..."
