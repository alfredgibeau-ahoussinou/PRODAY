{
  "name": "proday",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "description": "ProDay — plateforme mobile recrutement, tournois, matchs amicaux et sponsoring",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web --clear",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "typecheck": "tsc --noEmit",
    "cleanup:demo": "node scripts/cleanup-demo-data.mjs",
    "admin:setup": "node scripts/setup-admin.mjs",
    "stats:refresh": "node scripts/refresh-platform-stats.mjs",
    "firebase:health": "node scripts/firebase-health.mjs",
    "firebase:seed": "node scripts/seed-firestore.mjs",
    "firebase:deploy": "firebase deploy --only firestore:rules,firestore:indexes && npm run stats:refresh",
    "firebase:deploy:functions": "firebase deploy --only functions",
    "firebase:deploy:check": "node scripts/firebase-health.mjs",
    "firebase:deploy:storage": "firebase deploy --only storage",
    "firebase:rules:test": "firebase emulators:exec --only firestore \"node scripts/firestore-rules.test.mjs\"",
    "docs:cv": "node scripts/generate-player-cv.mjs",
    "docs:pdf": "pandoc docs/ProDay_Brief_NonDev.md -o docs/ProDay_Brief_NonDev.pdf --pdf-engine=pdflatex -V lang=fr -V geometry:margin=2.2cm -V colorlinks=true -V linkcolor=003399 2>/dev/null || pandoc docs/ProDay_Brief_NonDev.md -o docs/ProDay_Brief_NonDev.pdf -V lang=fr 2>/dev/null || echo '→ Ouvrir docs/design/ProDay_Brief.html et Imprimer → PDF'",
    "docs:open-mockups": "open docs/design/mockups/index.html",
    "docs:open-brief": "open docs/design/ProDay_Brief.html",
    "branding:logos": "node scripts/generate-transparent-logos.mjs",
    "docs:pactes": "node scripts/generate-pacte-pdf.mjs",
    "docs:guide-restant": "node scripts/generate-guide-restant-pdf.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:production": "eas build --profile production",
    "eas:submit:production": "eas submit --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^11.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "firebase-admin": "^13.10.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.9.2"
  }
}
