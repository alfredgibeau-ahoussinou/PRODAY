{
  "expo": {
    "name": "ProDay",
    "slug": "proday",
    "version": "1.0.0",
    "scheme": "proday",
    "orientation": "portrait",
    "icon": "./assets/branding/logo-light.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/branding/logo-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#F1F5F9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.proday.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/logo-light.png",
        "backgroundColor": "#F1F5F9"
      },
      "package": "com.proday.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/branding/logo-light.png"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "ProDay accède à vos photos pour votre avatar et votre galerie joueur."
        }
      ],
      "expo-web-browser"
    ]
  }
}
